<Window x:Class="TaskNinja.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:TaskNinja.Models"
        xmlns:vm="clr-namespace:TaskNinja.ViewModels"
        Title="TaskNinja"
        Width="460" Height="720"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Loaded="OnWindow_Loaded"
        Closing="OnWindow_Closing"
        StateChanged="OnWindow_StateChanged"
        KeyDown="OnWindow_KeyDown"
        MinWidth="380" MinHeight="420">

    <Window.Resources>
        <!-- DataTemplate for one task row. Bound to TaskItem.
             Compact by default (40px tall); displays just title, due, person chip,
             📎 chip if body has content. Hover shows preview popup.
        -->
        <DataTemplate x:Key="TaskRowTemplate" DataType="{x:Type m:TaskItem}">
            <Border x:Name="RowBorder"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,10"
                    MouseEnter="OnTaskRow_MouseEnter"
                    MouseLeave="OnTaskRow_MouseLeave"
                    MouseLeftButtonDown="OnTaskRow_MouseLeftButtonDown"
                    MouseRightButtonDown="OnTaskRow_RightClick"
                    Cursor="Hand">
                <!-- Hover state: slight PanelBrush background to signal
                     interactivity. The triggers route through Border.Style
                     since DataTemplate's outer element can't have direct
                     Style.Triggers. -->
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BgBrush}" />
                        <Style.Triggers>
                            <!-- Important: warm tint + amber left edge. Declared
                                 BEFORE the hover trigger so hover still wins on
                                 mouse-over (last matching trigger applies). -->
                            <DataTrigger Binding="{Binding IsImportant}" Value="True">
                                <Setter Property="Background" Value="#2E2418" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderThickness" Value="3,0,0,1" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu>
                        <!-- Status submenu — most-used action, so it goes first.
                             Equivalent to clicking the row's state glyph
                             cycling, but with the option to land on any state. -->
                        <MenuItem Header="Set status">
                            <MenuItem Header="○  Open"          Click="OnTaskMenu_SetOpen" />
                            <MenuItem Header="◐  In progress"   Click="OnTaskMenu_SetInProgress" />
                            <MenuItem Header="●  Done"          Click="OnTaskMenu_SetDone" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="✏️  Edit task…"        Click="OnTaskMenu_Edit" />
                        <MenuItem Header="❗ Toggle important"   Click="OnTaskMenu_ToggleImportant" />
                        <MenuItem Header="📅 Set due date…"     Click="OnTaskMenu_SetDueDate" />
                        <MenuItem Header="👤 Set responsible…"  Click="OnTaskMenu_SetPerson" />
                        <MenuItem Header="🔁 Set recurrence…"   Click="OnTaskMenu_SetRecurrence" />
                        <MenuItem Header="📂 Move to bucket…"   Click="OnTaskMenu_MoveBucket" />
                        <Separator />
                        <MenuItem Header="💤 Snooze">
                            <MenuItem Header="Tomorrow"           Click="OnTaskMenu_SnoozeTomorrow" />
                            <MenuItem Header="In 2 days"          Click="OnTaskMenu_Snooze2Days" />
                            <MenuItem Header="This weekend"       Click="OnTaskMenu_SnoozeWeekend" />
                            <MenuItem Header="In 1 week"          Click="OnTaskMenu_Snooze1Week" />
                            <MenuItem Header="In 2 weeks"         Click="OnTaskMenu_Snooze2Weeks" />
                            <Separator />
                            <MenuItem Header="Next week (+7d)"    Click="OnTaskMenu_SnoozeNextWeek" />
                            <MenuItem Header="Pick a date..."     Click="OnTaskMenu_SnoozePickDate" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="📦 Archive"   Click="OnTaskMenu_Archive" />
                        <MenuItem Header="🗑️ Delete…"  Click="OnTaskMenu_Delete" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- state glyph -->
                        <ColumnDefinition Width="*" />     <!-- title -->
                        <ColumnDefinition Width="Auto" />  <!-- chips -->
                    </Grid.ColumnDefinitions>

                    <!-- State glyph (○ ◐ ●) — clickable to cycle state -->
                    <Border Grid.Column="0"
                            Background="Transparent"
                            Width="26" Height="26"
                            Margin="0,0,8,0"
                            MouseLeftButtonUp="OnStateGlyph_Click"
                            ToolTip="Click to change state — opens a picker so you can pick deliberately."
                            Cursor="Hand">
                        <TextBlock Text="{Binding StateGlyph}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Title — strikethrough when Done -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- Important marker. Visibility bound so it takes
                                 no space at all on ordinary tasks. -->
                            <TextBlock x:Name="ImportantMark"
                                       Text="❗"
                                       FontSize="13"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       ToolTip="Important"
                                       Visibility="{Binding IsImportant, Converter={StaticResource BoolToVis}}" />
                            <TextBlock x:Name="TitleBlock"
                                       Text="{Binding Title}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Tag chips — click one to filter the whole list to
                             that tag (across every bucket). -->
                        <ItemsControl x:Name="TagChips"
                                      ItemsSource="{Binding AllTags}"
                                      Margin="0,3,0,0"
                                      Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,1"
                                            Margin="0,0,4,2"
                                            Cursor="Hand"
                                            ToolTip="Filter to this tag (all buckets)"
                                            MouseLeftButtonDown="OnTagChip_Click">
                                        <!-- "#" + tag as two TextBlocks rather than
                                             StringFormat=#{0}: inside a markup
                                             extension the XAML parser reads the
                                             inner {0} as a NESTED extension and
                                             fails to compile. Two blocks, zero
                                             cleverness. -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="#"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SkyBrush}" />
                                            <TextBlock Text="{Binding}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SkyBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Bucket name shown subtly when viewing "All" -->
                        <TextBlock x:Name="BucketHint"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource DimTextBrush}"
                                   FontSize="12"
                                   FontFamily="Consolas" />
                    </StackPanel>

                    <!-- Right-side chips -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Person chip -->
                        <Border Style="{StaticResource ChipStyle}"
                                Margin="4,0,0,0"
                                Visibility="{Binding ResponsiblePerson, Converter={StaticResource StringToVisConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤 " FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ResponsiblePerson}"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Has-content chip — 📎 if body or attachments exist -->
                        <Border x:Name="ContentChip"
                                Style="{StaticResource ChipStyle}"
                                Margin="4,0,0,0"
                                Visibility="Collapsed">
                            <TextBlock Foreground="{StaticResource SkyBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center">
                                <Run Text="📎" />
                            </TextBlock>
                        </Border>

                        <!-- URL chip — 🔗 N when body contains URLs (parallels
                             ClipNinja's URL indicator). The number tells you
                             how many links are tucked in the body. -->
                        <Border x:Name="UrlChip"
                                Style="{StaticResource ChipStyle}"
                                Margin="4,0,0,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔗 " FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding UrlCount}"
                                           Foreground="{StaticResource SkyBrush}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Recurrence chip — 🔁 if recurring -->
                        <Border x:Name="RecurChip"
                                Style="{StaticResource ChipStyle}"
                                Margin="4,0,0,0"
                                Visibility="Collapsed">
                            <TextBlock Text="🔁" FontSize="12" VerticalAlignment="Center" />
                        </Border>

                        <!-- Due date chip — colored by DueState -->
                        <Border x:Name="DueChip"
                                Style="{StaticResource ChipStyle}"
                                Margin="4,0,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="DueText"
                                       Text="{Binding DueLabel}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <!-- Done = strikethrough + dim -->
                <DataTrigger Binding="{Binding IsDone}" Value="True">
                    <Setter TargetName="TitleBlock" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="TitleBlock" Property="Foreground" Value="{StaticResource DoneBrush}" />
                </DataTrigger>
                <!-- Show 📎 chip when HasContent -->
                <DataTrigger Binding="{Binding HasContent}" Value="True">
                    <Setter TargetName="ContentChip" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <!-- Show 🔗 N chip when body contains URLs -->
                <DataTrigger Binding="{Binding HasUrls}" Value="True">
                    <Setter TargetName="UrlChip" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <!-- Show recurrence chip when not None -->
                <DataTrigger Binding="{Binding Recurrence}" Value="Daily">
                    <Setter TargetName="RecurChip" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Recurrence}" Value="Weekly">
                    <Setter TargetName="RecurChip" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Recurrence}" Value="Monthly">
                    <Setter TargetName="RecurChip" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Recurrence}" Value="Yearly">
                    <Setter TargetName="RecurChip" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <!-- Color the due-date chip by DueState -->
                <DataTrigger Binding="{Binding DueState}" Value="Overdue">
                    <Setter TargetName="DueChip" Property="Visibility" Value="Visible" />
                    <Setter TargetName="DueText" Property="Foreground" Value="{StaticResource OverdueBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DueState}" Value="Today">
                    <Setter TargetName="DueChip" Property="Visibility" Value="Visible" />
                    <Setter TargetName="DueText" Property="Foreground" Value="{StaticResource TodayBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DueState}" Value="Soon">
                    <Setter TargetName="DueChip" Property="Visibility" Value="Visible" />
                    <Setter TargetName="DueText" Property="Foreground" Value="{StaticResource SoonBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DueState}" Value="Later">
                    <Setter TargetName="DueChip" Property="Visibility" Value="Visible" />
                    <Setter TargetName="DueText" Property="Foreground" Value="{StaticResource SubTextBrush}" />
                </DataTrigger>
                <!-- Done tasks: chip shows the completion date ("✓ Jul 8")
                     in the sage/positive tone. -->
                <DataTrigger Binding="{Binding DueState}" Value="Done">
                    <Setter TargetName="DueChip" Property="Visibility" Value="Visible" />
                    <Setter TargetName="DueText" Property="Foreground" Value="{StaticResource SoonBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer frame — rounded corners on transparent window.
         AllowDrop=True so users can drag emails from Outlook, files from
         Explorer, or images into the app to create new tasks. The Drop
         handler in code-behind decodes the various clipboard formats. -->
    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            AllowDrop="True"
            DragEnter="OnWindow_DragEnter"
            DragOver="OnWindow_DragOver"
            DragLeave="OnWindow_DragLeave"
            Drop="OnWindow_Drop">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0: title bar -->
                <RowDefinition Height="Auto" />  <!-- 1: toolbar -->
                <RowDefinition Height="Auto" />  <!-- 2: quick-add bar (collapsed) -->
                <RowDefinition Height="Auto" />  <!-- 3: filter row -->
                <RowDefinition Height="Auto" />  <!-- 4: contextual action bar (collapsed except in Done filter) -->
                <RowDefinition Height="Auto" />  <!-- 5: search row (collapsed) -->
                <RowDefinition Height="*" />     <!-- 6: task list -->
                <RowDefinition Height="Auto" />  <!-- 7: status bar -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="OnTitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,3,0,3">
                        <!-- Glyph: scroll with checkmark -->
                        <Viewbox Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Canvas Width="16" Height="16">
                                <!-- Scroll body -->
                                <Rectangle Canvas.Left="3" Canvas.Top="3"
                                           Width="10" Height="10"
                                           Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                           Fill="Transparent" RadiusX="1" RadiusY="1" />
                                <!-- Checkmark inside -->
                                <Polyline Points="5,8 7,10 11,5"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="1.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="Bold">
                            <Run Text="TaskNinja" />
                            <Run x:Name="VersionRun"
                                 Foreground="{StaticResource SubTextBrush}"
                                 FontWeight="Normal" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="_"
                                ToolTip="Minimize"
                                Click="OnMinimize_Click" />
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="✕"
                                ToolTip="Hide to tray"
                                Click="OnClose_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar: bucket dropdown on left, primary + Add on right.
                 Bucket gets the wider real estate because it's used more often;
                 + Add is the primary action so it gets the amber pop. -->
            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Bucket dropdown — fills remaining width -->
                    <ComboBox Grid.Column="0"
                              x:Name="BucketCombo"
                              Style="{StaticResource DarkComboBoxStyle}"
                              SelectionChanged="OnBucketCombo_SelectionChanged"
                              Margin="0,0,8,0" />

                    <!-- Reports menu — opens a small menu offering Daily
                         summary and Weekly report. Cleaner than two
                         separate buttons (toolbar real estate is precious),
                         and keeps both reports discoverable from inside
                         the app instead of forcing users to find them
                         through the tray menu. -->
                    <Button Grid.Column="1"
                            x:Name="ReportsBtn"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="📊"
                            FontSize="14"
                            Margin="0,0,8,0"
                            Click="OnReports_Click"
                            ToolTip="Reports — daily summary &amp; weekly activity">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ReportsMenu">
                                <MenuItem Header="📋  Daily summary (Ctrl+D)"
                                          Click="OnShowDailyDigest_Click" />
                                <MenuItem Header="📊  Weekly report (Ctrl+R)"
                                          Click="OnShowWeeklyReport_Click" />
                                <Separator />
                                <MenuItem Header="⚙  Notification settings…"
                                          Click="OnNotificationSettings_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Manage buckets gear -->
                    <Button Grid.Column="2"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="⚙"
                            FontSize="14"
                            Margin="0,0,8,0"
                            Click="OnManageBuckets_Click"
                            ToolTip="Add / rename / delete buckets" />

                    <!-- + Add task — PRIMARY action -->
                    <Button Grid.Column="3"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="+ Add task"
                            Click="OnAddTask_Click"
                            ToolTip="Add a new task (Ctrl+N)" />
                </Grid>
            </Border>

            <!-- Quick-add bar (Row 2). Hidden by default; appears when user clicks + Add. -->
            <Border Grid.Row="2"
                    x:Name="QuickAddBar"
                    Background="{StaticResource PanelLightBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="0,0,0,2"
                    Padding="12,10"
                    Visibility="Collapsed">
                <StackPanel>
                    <!-- Bucket selector for the new task. Defaults to the
                         currently-active bucket so users don't have to think
                         about it most of the time, but they can override here
                         when adding a task that belongs elsewhere. -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Bucket"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1"
                                  x:Name="QuickAddBucket"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  ToolTip="Which bucket does this task go in?" />
                    </Grid>

                    <!-- Title field with explicit label -->
                    <TextBlock Text="Task title"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="0,0,0,3" />
                    <TextBox x:Name="QuickAddText"
                             FontSize="14"
                             Padding="8,6"
                             Background="{StaticResource BgBrush}"
                             Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             KeyDown="OnQuickAdd_KeyDown"
                             ToolTip="What needs doing? Use #tag inline for tags." />

                    <!-- Optional fields row, each with its own label so the
                         purpose of each box is unambiguous. Three labeled
                         columns: Due date | Responsible | (save/cancel buttons) -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Labels row -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Due date"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="0,0,4,3" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="Responsible person"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="4,0,4,3" />

                        <!-- DatePicker with our dark calendar style. The user
                             can pick from the calendar OR type in the textbox
                             part; the typed parsing supports "today", "tomorrow",
                             weekday names, and YYYY-MM-DD. -->
                        <DatePicker Grid.Row="1" Grid.Column="0"
                                    x:Name="QuickAddDate"
                                    Style="{StaticResource DarkDatePickerStyle}"
                                    Margin="0,0,4,0"
                                    ToolTip="Pick a date from the calendar, or type 'today', 'tomorrow', 'fri', or YYYY-MM-DD" />

                        <TextBox Grid.Row="1" Grid.Column="1"
                                 x:Name="QuickAddPerson"
                                 Margin="4,0,4,0"
                                 FontSize="13"
                                 Padding="6,4"
                                 Background="{StaticResource BgBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 ToolTip="Who's doing this? (optional)" />

                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Save"
                                    Margin="4,0,0,0"
                                    Padding="14,4"
                                    Click="OnQuickAddSave_Click" />
                            <Button Style="{StaticResource ToolbarButtonStyle}"
                                    Content="✕"
                                    Margin="4,0,0,0"
                                    Click="OnQuickAddCancel_Click"
                                    ToolTip="Cancel (Esc)" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Tip: type the title, press Enter to save. Use #tag in title for tags."
                               Style="{StaticResource HintTextStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- Filter row -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Filter pills — radio-button group but visually styled
                         as toggle pills. Active pill takes amber background +
                         bold dark text via FilterPillStyle's IsChecked trigger.
                         WrapPanel (not StackPanel): six pills don't fit the
                         default 460px window width on one line — a StackPanel
                         silently clipped the Done pill off the right edge
                         after Scheduled was added in v1.0.25. Wrapping keeps
                         every pill reachable at any window width. -->
                    <WrapPanel Grid.Column="0" Orientation="Horizontal">
                        <RadioButton x:Name="FilterAll"       Style="{StaticResource FilterPillStyle}" Content="All"       Checked="OnFilter_Changed" Tag="All" IsChecked="True" />
                        <RadioButton x:Name="FilterToday"     Style="{StaticResource FilterPillStyle}" Content="Today"     Checked="OnFilter_Changed" Tag="Today" />
                        <RadioButton x:Name="FilterWeek"      Style="{StaticResource FilterPillStyle}" Content="Week"      Checked="OnFilter_Changed" Tag="ThisWeek" />
                        <RadioButton x:Name="FilterOverdue"   Style="{StaticResource FilterPillStyle}" Content="Overdue"   Checked="OnFilter_Changed" Tag="Overdue" />
                        <RadioButton x:Name="FilterScheduled" Style="{StaticResource FilterPillStyle}" Content="Scheduled" Checked="OnFilter_Changed" Tag="Scheduled"
                                     ToolTip="Tasks waiting in the wings — recurring spawns deferred until closer to due, plus anything manually deferred via 'Don't show until'." />
                        <RadioButton x:Name="FilterDone"      Style="{StaticResource FilterPillStyle}" Content="Done"      Checked="OnFilter_Changed" Tag="Done" />
                        <!-- Active tag filter — appears inline with the pills
                             when a tag chip is clicked. Click to clear. Lives
                             in the same WrapPanel so it wraps with them
                             instead of stealing a whole row. -->
                        <Border x:Name="ActiveTagChip"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="10"
                                Padding="8,3"
                                Margin="4,3,4,3"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                ToolTip="Clear tag filter"
                                MouseLeftButtonDown="OnClearTag_Click"
                                Visibility="{Binding HasActiveTag, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#1A1712">
                                <Run Text="{Binding ActiveTagLabel, Mode=OneWay}" />
                                <Run Text="  ✕" />
                            </TextBlock>
                        </Border>
                    </WrapPanel>
                    <!-- Sort mode toggle — cycles "Due date" ↔ "Manual".
                         Manual mode is auto-engaged on first drag-and-drop;
                         this button lets the user swap back to date sort or
                         opt into manual without dragging first. -->
                    <Button Grid.Column="1"
                            x:Name="SortToggleBtn"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="↕ Date"
                            FontSize="11"
                            Padding="8,4"
                            Margin="0,0,4,0"
                            Click="OnSortToggle_Click"
                            ToolTip="Toggle sort: Due date ↔ Manual (drag-and-drop)" />
                    <Button Grid.Column="2"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="🔍"
                            FontSize="13"
                            Padding="10,4"
                            Click="OnSearchToggle_Click"
                            ToolTip="Search (Ctrl+F)" />
                </Grid>
            </Border>

            <!-- Contextual action bar (Row 4) — collapsed by default, only
                 appears when the Done filter is active. Gives the user a
                 bulk "archive everything done" action so completed tasks
                 don't accumulate in the Done view forever. -->
            <Border Grid.Row="4"
                    x:Name="DoneActionsBar"
                    Background="{StaticResource PanelLightBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,6"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="12"
                               Text="Done tasks pile up — archive them when you're ready." />
                    <Button Grid.Column="1"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="📦 Archive all done"
                            FontSize="12"
                            Click="OnArchiveAllDone_Click"
                            ToolTip="Move every Done task in this view to the archive (recoverable)" />
                </Grid>
            </Border>

            <!-- Search row (Row 5) — collapsed by default, expands on Ctrl+F or 🔍 -->
            <Border Grid.Row="5"
                    x:Name="SearchBar"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="SearchBox"
                             FontSize="13"
                             Padding="8,5"
                             Background="{StaticResource BgBrush}"
                             Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             TextChanged="OnSearch_TextChanged"
                             KeyDown="OnSearch_KeyDown" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Style="{StaticResource ToolbarButtonStyle}"
                            FontSize="12"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Click="OnSearchClose_Click"
                            ToolTip="Close search (Esc)" />
                </Grid>
            </Border>

            <!-- Task list -->
            <ListBox Grid.Row="6"
                     x:Name="TaskList"
                     ItemsSource="{Binding VisibleTasks}"
                     ItemTemplate="{StaticResource TaskRowTemplate}"
                     Background="{StaticResource BgBrush}"
                     BorderThickness="0"
                     AllowDrop="True"
                     PreviewMouseLeftButtonDown="OnTaskList_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="OnTaskList_PreviewMouseMove"
                     Drop="OnTaskList_Drop"
                     DragOver="OnTaskList_DragOver"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Empty-state hint -->
            <TextBlock Grid.Row="6"
                       IsHitTestVisible="False"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="20,80,20,0"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource SubTextBrush}"
                       Text="📋 No tasks here.&#10;&#10;Click + Add task (or press Ctrl+N) to create one.&#10;Type a #tag in the title to organize.&#10;Drag to reorder once you have a few.">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VisibleTasks.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Status bar -->
            <Border Grid.Row="7"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,6,6"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="StatusLine"
                               Text="{Binding StatusText}"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontFamily="Consolas"
                               VerticalAlignment="Center">
                        <Run Text="open: " />
                        <Run Text="{Binding OpenCount, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        <Run Text="   done today: " />
                        <Run Text="{Binding DoneTodayCount, Mode=OneWay}" Foreground="{StaticResource SageBrush}" FontWeight="Bold" />
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Drop overlay — visible only during a drag-over. Spans all
                 8 grid rows so it covers the entire content. IsHitTestVisible
                 is False so it doesn't intercept the drag events (which we
                 want handled by the outer Border). -->
            <Border x:Name="DropOverlay"
                    Grid.Row="0"
                    Grid.RowSpan="8"
                    Background="#CC1F1A14"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="6"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📥"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Drop to create a new task"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Email from Outlook, image, file, or text — all work"
                               FontSize="12"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource SubTextBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
