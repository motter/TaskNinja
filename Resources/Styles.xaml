<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Subtle hint text used in footer and placeholders -->
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource DimTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Consolas" />
    </Style>

    <!-- Title bar button (close, minimize) -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource SubTextBrush}" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="26" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBg" Property="Background" Value="{StaticResource PanelLightBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary toolbar button — used for ⚙ etc. -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBg" Property="Background" Value="{StaticResource PanelLightBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PRIMARY button — amber background, dark text. Used for "+ Add task" so
         the most important action is the visually loudest one. -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="#1F1A14" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PrimaryBg"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <!-- Slightly darker amber on hover -->
                            <Setter TargetName="PrimaryBg" Property="Background" Value="#C98430" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filter PILL — used in the filter strip (All / Today / Week / Overdue / Done).
         Replaces the previous tiny RadioButton controls; styled as toggle pills.
         When IsChecked=True the pill takes on accent color. -->
    <Style x:Key="FilterPillStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource SubTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <!-- 3px top+bottom so wrapped rows (narrow window) don't touch;
             costs nothing on a single-line layout. -->
        <Setter Property="Margin" Value="0,3,4,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="PillBg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PillBg" Property="Background" Value="{StaticResource PanelLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PillBg" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="PillBg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="#1F1A14" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Chip — colored pill used for due date, person, attachment count -->
    <Style x:Key="ChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelLightBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ComboBox: dark with amber dropdown popup.
         WPF's default ComboBox theme uses system light colors for the
         dropdown list regardless of what you set on the closed state, so
         we have to override the entire ControlTemplate including the Popup
         to keep our palette consistent. The dropdown uses AccentBrush
         (amber/ochre) as background with dark text for contrast — the
         user-requested "yellow ochre" treatment.

         Two interacting styles below:
           - DarkComboBoxItemStyle    controls each row in the popup
           - DarkComboBoxStyle        controls the closed-state face AND
                                      wires the popup to use the amber bg
    -->
    <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="#1F1A14" />  <!-- BgBrush color directly for dark text on amber -->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBg"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <!-- Slightly darker amber on hover -->
                            <Setter TargetName="ItemBg" Property="Background" Value="#C98430" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="#C98430" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <!-- Outer Grid with explicit content + arrow columns.
                         PART_EditableTextBox is constrained to column 0, so
                         the arrow column 1 stays clickable when IsEditable=True
                         (otherwise the textbox covers the arrow and the
                         dropdown never opens, which was the bug fixed here). -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                        </Grid.ColumnDefinitions>

                        <!-- ToggleButton spans BOTH columns: provides the
                             background fill, the border, and the click-anywhere-
                             to-open behavior (when not editable). When editable,
                             only its right-column hit area is exposed (the
                             textbox covers col 0) — but that's the arrow zone
                             which is exactly where the user expects to click
                             to drop down a list. -->
                        <ToggleButton Grid.Column="0"
                                      Grid.ColumnSpan="2"
                                      Name="ToggleButton"
                                      Focusable="False"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ButtonBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelLightBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ToggleButton.Background>
                                <SolidColorBrush Color="#2A2218" />
                            </ToggleButton.Background>
                        </ToggleButton>

                        <!-- Arrow glyph in column 1. IsHitTestVisible=False so
                             clicks pass through to the underlying ToggleButton. -->
                        <Path Grid.Column="1"
                              IsHitTestVisible="False"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{StaticResource AccentBrush}"
                              Data="M 0 0 L 4 4 L 8 0 Z" />

                        <!-- The selected-item display (non-editable mode). Sits
                             in column 0 only, so the arrow column shows the
                             chevron Path above. -->
                        <ContentPresenter Name="ContentSite"
                                          Grid.Column="0"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          TextBlock.Foreground="{StaticResource TextBrush}" />

                        <!-- Editable textbox overlay. CRITICAL: Grid.Column="0"
                             (NOT spanning) so the arrow column stays clickable.
                             Before this fix, the textbox covered the arrow and
                             swallowed clicks meant for the dropdown toggle. -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Grid.Column="0"
                                 Visibility="Hidden"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0"
                                 Padding="{TemplateBinding Padding}"
                                 VerticalAlignment="Center"
                                 Focusable="True"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />

                        <!-- The dropdown popup itself — AMBER BACKGROUND, dark text via ItemContainerStyle -->
                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource AccentBrush}"
                                    BorderBrush="#8B6228"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ────────────────────────────────────────────────────────────
         Dark-themed DatePicker
         ────────────────────────────────────────────────────────────
         WPF's default DatePicker calendar popup uses Windows system
         colors that are almost always light, even when the host app
         is dark. Restyling requires overriding the templates for:
           • DatePickerTextBox  — the inline text field
           • Calendar / CalendarItem / CalendarDayButton / CalendarButton
             — the popup calendar grid
         The Calendar template is reused by all DatePickers in the app
         (we set it as the default Style for the Calendar type), so we
         don't have to opt-in per DatePicker for the popup styling.
    -->

    <!-- Style applied to the Calendar inside any DatePicker popup. We
         leave x:Key off so this is the default for ALL Calendar instances
         in the app — which is what we want, since the DatePicker's
         popup creates a Calendar internally and we have no way to inject
         a Style by key. -->
    <Style TargetType="{x:Type Calendar}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Style the individual day buttons inside the Calendar. Selected
         day gets amber background; today gets a subtle amber border.
         Other days inherit text color from the Calendar. -->
    <Style TargetType="{x:Type CalendarDayButton}">
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarDayButton}">
                    <Border x:Name="DayBg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DayBg" Property="Background" Value="{StaticResource PanelLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="DayBg" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="#1F1A14" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="DayBg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DimTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The month/year navigation buttons at the top of the Calendar
         popup (« and » arrows, month name). -->
    <Style TargetType="{x:Type CalendarButton}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarButton}">
                    <Border x:Name="BtnBg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Padding="6,3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBg" Property="Background" Value="{StaticResource PanelLightBrush}" />
                        </Trigger>
                        <!-- Note: CalendarButton is the month/year navigation
                             button. It does NOT have an IsSelected property
                             (that's only on CalendarDayButton). Clicking a
                             CalendarButton navigates the calendar rather than
                             toggling a persistent selection, so a "selected"
                             visual state isn't needed here. -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBg" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="#1F1A14" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DatePickerTextBox — the inline text field part of the DatePicker.
         We give it the same dark surface treatment as our normal TextBoxes.
         This is a default style (no x:Key) so it applies to every
         DatePickerTextBox in any DatePicker. -->
    <Style TargetType="{x:Type DatePickerTextBox}">
        <Setter Property="Background" Value="{StaticResource BgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Main DatePicker style. References a custom ControlTemplate
         so the dropdown button (the little calendar icon) renders in
         our amber palette instead of the system default. The watermark
         (placeholder text) is also overridden because the default is
         "Select a date" in white-on-white otherwise. -->
    <Style x:Key="DarkDatePickerStyle" TargetType="{x:Type DatePicker}">
        <Setter Property="Background" Value="{StaticResource BgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- The text-entry portion of the DatePicker.
                                 PART_TextBox is the named slot WPF replaces
                                 with a DatePickerTextBox internally. -->
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Focusable="{TemplateBinding Focusable}"
                                               Background="{TemplateBinding Background}"
                                               Foreground="{TemplateBinding Foreground}"
                                               BorderThickness="0" />
                            <!-- Calendar dropdown trigger -->
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Focusable="False"
                                    HorizontalAlignment="Right"
                                    Width="26"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Content="📅"
                                    Foreground="{StaticResource AccentBrush}"
                                    FontSize="13">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DropBg"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="0,3,3,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DropBg"
                                                        Property="Background"
                                                        Value="{StaticResource PanelLightBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- The popup that hosts the Calendar. WPF
                                 instantiates the Calendar with our default
                                 Calendar Style above, so the popup contents
                                 inherit the dark palette automatically. -->
                            <Popup x:Name="PART_Popup"
                                   PlacementTarget="{Binding ElementName=PART_TextBox}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
